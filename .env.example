DATABASE_URL="postgresql://assemblyline:assemblyline@localhost:5432/assemblyline"
REDIS_URL="redis://localhost:6379"
QUEUE_MODE="inline"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-at-least-32-characters"
ENCRYPTION_KEY="replace-with-32-byte-base64-key"
STORAGE_ROOT="./storage"
LOG_LEVEL="info"

# Optional app sign-in OAuth providers. Add both ID and secret to show the provider on /signin.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Optional live provider smoke test.
OPENAI_API_KEY=""
OPENAI_SMOKE_MODEL="gpt-4.1-mini"
STABILITY_API_KEY=""
STABILITY_SMOKE_MODEL="stable-image-core"
RUNWAYML_API_SECRET=""
RUNWAY_SMOKE_MODEL="gen4.5"
